# Caddy автоматически получает и продлевает HTTPS-сертификат Let's Encrypt.
# Замени домен через переменную DIGEST_DOMAIN в .env.
# Авторизация (вход по QR через Telegram) реализована внутри приложения,
# поэтому здесь только проксирование + автоматический HTTPS.

{$DIGEST_DOMAIN} {
    reverse_proxy digest:8080
}
