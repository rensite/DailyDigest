# ===== Gmail (IMAP) =====
# Включите 2FA в Google-аккаунте и создайте App Password:
# https://myaccount.google.com/apppasswords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Сколько последних писем из "Входящих" анализировать
GMAIL_MAX_EMAILS=20
# Анализировать только непрочитанные? (true/false)
GMAIL_UNREAD_ONLY=true

# ===== Telegram =====
# Создайте бота у @BotFather и вставьте токен.
# CHAT_ID можно узнать, написав боту и открыв:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# ===== Погода (Open-Meteo, без ключа) =====
# Координаты Москвы по умолчанию
WEATHER_LAT=55.7558
WEATHER_LON=37.6173
WEATHER_CITY=Москва
WEATHER_TZ=Europe/Moscow

# ===== Новости (RSS) =====
# Список RSS-лент через запятую
NEWS_FEEDS=https://lenta.ru/rss/news,https://www.vedomosti.ru/rss/news,https://habr.com/ru/rss/best/daily/?fl=ru
NEWS_MAX_ITEMS=8

# ===== Курсы валют (ЦБ РФ, без ключа) =====
# Какие валюты показывать к рублю (коды через запятую)
CURRENCIES=USD,EUR

# ===== Расписание =====
# Время ежедневной сводки (по WEATHER_TZ), формат HH:MM
DIGEST_TIME=08:00

# ===== Веб =====
WEB_HOST=0.0.0.0
WEB_PORT=8080

# ===== Авторизация (вход по QR через Telegram) =====
# true — дашборд закрыт, вход по QR (нужен Telegram-бот и твой CHAT_ID).
# false — открытый доступ (только для локального/SSH-туннеля).
AUTH_ENABLED=true
# Домен дашборда (для Caddy + HTTPS). Например: digest.example.com
DIGEST_DOMAIN=digest.example.com
# Secure-cookie: true для HTTPS (прод), false если открываешь по http://IP
COOKIE_SECURE=true

# ===== LLM (умный слой) =====
# Какой провайдер использовать: openai | anthropic | grok | gemini
# Оставьте пустым, чтобы выключить умный слой (сводка останется обычной).
LLM_PROVIDER=anthropic
# Модель — оставьте пустым для дефолта провайдера, или укажите свою:
#   openai     -> gpt-4o-mini (дефолт), gpt-4o, ...
#   anthropic  -> claude-3-5-haiku-latest (дефолт), claude-3-5-sonnet-latest, ...
#   grok       -> grok-2-latest (дефолт)
#   gemini     -> gemini-1.5-flash (дефолт), gemini-1.5-pro
LLM_MODEL=

# Ключи (нужен только тот, что соответствует LLM_PROVIDER):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
GEMINI_API_KEY=

# ===== Профиль (персонализация под тебя) =====
# Чем подробнее — тем точнее ассистент попадает «в тебя».
PROFILE_NAME=Денис
PROFILE_ROLE=Развитие бизнеса, BizDev
PROFILE_PRIORITIES=Закрыть сделки квартала, не упускать важные письма от клиентов
PROFILE_INTERESTS=Технологии, стартапы, экономика, AI
PROFILE_EXTRA=
